# Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# n8n Webhook (REQUIRED for mission uploads)
VITE_N8N_WEBHOOK_URL=your_n8n_webhook_url_here

# Robolly (Optional - for future ad generation)
ROBOLLY_API_KEY=your_robolly_api_key
ROBOLLY_TEMPLATE_ID=your_robolly_template_id

# Supabase Service Role (Backend only - DO NOT expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
